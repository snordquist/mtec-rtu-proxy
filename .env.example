# Copy to .env and fill in YOUR values. .env is gitignored - never commit it.
# The addresses below use the RFC 5737 documentation range (192.0.2.0/24);
# they are placeholders, not real hosts.

# Where the proxy listens (clients: your EMS/Hero and Home Assistant connect here)
LISTEN_HOST=0.0.0.0
LISTEN_PORT=502

# The M-TEC "espressif" Modbus dongle (RTU-over-TCP)
DONGLE_HOST=192.0.2.10
DONGLE_PORT=502

# Comma-separated IPs that get PRIORITY + always-live reads (your EMS / EnergyHero).
# Everyone else (e.g. Home Assistant) is answered from the register cache.
HERO_IPS=192.0.2.20

# Optional: force this Modbus unit id when talking to the dongle (leave unset to
# pass each client's unit through). The espressif answers unit 252; MBAP clients
# such as the EnergyHero often use 255 - set 252 to normalise to the working unit.
# DONGLE_UNIT=252

# Tuning (seconds)
TXN_TIMEOUT=3.0
CACHE_TTL=30
RECONNECT_BACKOFF=3.0
CONNECT_SETTLE=2.0

# Debugging: set DEBUG to log every request/reply with decoded register values
LOG_LEVEL=INFO
# Log a one-line stats summary (cache_hits/live/timeouts/drained/reconnects) every N s (0=off)
STATS_INTERVAL=60

# Gentleness / load control for a flaky dongle:
# minimum seconds between upstream requests (0 = off); e.g. 0.08 caps ~12 req/s
MIN_REQUEST_INTERVAL=0.0
# if >0, also serve HERO reads from cache within this window (debounce duplicate polls)
HERO_CACHE_TTL=0.0
