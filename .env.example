# Copy to .env and fill in YOUR values. .env is gitignored - never commit it.
# The addresses below use the RFC 5737 documentation range (192.0.2.0/24);
# they are placeholders, not real hosts.

# Where the proxy listens (all clients connect here).
LISTEN_HOST=0.0.0.0
LISTEN_PORT=502

# The upstream Modbus device (an RTU-over-TCP gateway / WiFi dongle).
UPSTREAM_HOST=192.0.2.10
UPSTREAM_PORT=502

# Comma-separated client IPs that get PRIORITY + always-live reads (e.g. your
# EMS/controller). Everyone else is answered from the register cache (if enabled).
PRIORITY_IPS=192.0.2.20

# Comma-separated IPs allowed to send FC06/FC16 WRITES (commanding the device).
# Defaults to PRIORITY_IPS if unset. Add other legitimate writers here.
# LEAVE EMPTY ONLY IN A TRUSTED LAB: an empty list accepts writes from ANY client.
WRITE_IPS=192.0.2.20,192.0.2.30

# Optional: force this Modbus unit id upstream (leave unset to pass each client's
# unit through). Useful when a client uses a different unit id than the device.
# UPSTREAM_UNIT=252

# Tuning (seconds)
TXN_TIMEOUT=3.0
CACHE_TTL=30            # read-through cache lifetime; set 0 to DISABLE caching (always live)
RECONNECT_BACKOFF=3.0
CONNECT_SETTLE=2.0

# Debugging: set DEBUG to log every request/reply with decoded register values
LOG_LEVEL=INFO
# Log a one-line stats summary (cache_hits/live/timeouts/drained/reconnects) every N s (0=off)
STATS_INTERVAL=60

# Load control for a fragile upstream:
# minimum seconds between upstream requests (0 = off); e.g. 0.08 caps ~12 req/s
MIN_REQUEST_INTERVAL=0.0
# if >0, also serve PRIORITY reads from cache within this window (debounce duplicate polls)
PRIORITY_CACHE_TTL=0.0
# random 0..N s subtracted per cache write so blocks (read in one poll burst) expire
# staggered instead of all at once -> steady trickle to the device, not a refresh spike
CACHE_JITTER=0.0

# --- Backward-compatible aliases (still accepted) ---------------------------------
# The former M-TEC-flavoured names map to the generic ones above:
#   DONGLE_HOST -> UPSTREAM_HOST, DONGLE_PORT -> UPSTREAM_PORT, DONGLE_UNIT -> UPSTREAM_UNIT,
#   HERO_IPS -> PRIORITY_IPS, HERO_CACHE_TTL -> PRIORITY_CACHE_TTL
# See the README "Example: M-TEC Energy Butler + EnergyHero" section.
